[Version]
Signature="$Windows NT$"
Class=DuoController
ClassGuid={070D9FF9-4F04-4419-90D2-C4CA9DFDB2EE}
Provider=%ManufacturerName%
CatalogFile=DuoController.cat
PnpLockDown=1
DriverVer= 

[Manufacturer]
%ManufacturerName%=Standard,NT$ARCH$.10.0...17134

[Standard.NT$ARCH$.10.0...17134]
%ROOT\VID_054C&PID_0DF2.DeviceName%=DuoController_Install, ROOT\VID_054C&PID_0DF2

[ControlFlags]
ExcludeFromSelect=ROOT\VID_054C&PID_0DF2

[ClassInstall32]
AddReg=DuoControllerClass_RegistryAdd

[DuoControllerClass_RegistryAdd]
HKR,,,,%ClassName%
HKR,,Icon,,"-24"

[SourceDisksFiles]
DuoController.dll=1

[SourceDisksNames]
1 = %DiskName%

; =================== UMDF Device ==================================

[DuoController_Install.NT.hw.AddReg]
HKR,,"LowerFilters",0x00010008,"WUDFRd"

; DuoController
[DuoController_Install]
UmdfLibraryVersion=$UMDFVERSION$ 
ServiceBinary=%13%\DuoController.dll

[DuoController_Install.NT]
CopyFiles=UMDriverCopy

[DuoController_Install.NT.Services]
AddService=WUDFRd,0x000001f8,WUDFRD_ServiceInstall
AddService=mshidumdf, 0x000001fa, mshidumdf.AddService

[DuoController_Install.NT.hw]
AddReg=DuoController_Install.NT.hw.AddReg

[DuoController_Install.NT.Wdf]
UmdfService=DuoController,DuoController_Install
UmdfServiceOrder=DuoController
UmdfKernelModeClientPolicy=AllowKernelModeClients
UmdfFileObjectPolicy=AllowNullAndUnknownFileObjects
UmdfMethodNeitherAction=Copy
UmdfFsContextUsePolicy=CanUseFsContext2
UmdfHostPriority=PriorityHigh

[DuoController_Install.NT.CoInstallers]
AddReg=CoInstallers_AddReg

[WUDFRD_ServiceInstall]
DisplayName = %WudfRdDisplayName%
ServiceType = 1
StartType = 3
ErrorControl = 1
ServiceBinary = %13%\WUDFRd.sys

[mshidumdf.AddService]
ServiceType    = 1                  ; SERVICE_KERNEL_DRIVER
StartType      = 3                  ; SERVICE_DEMAND_START
ErrorControl   = 1                  ; SERVICE_ERROR_NORMAL
ServiceBinary  = %13%\mshidumdf.sys

[CoInstallers_AddReg]
HKR,,CoInstallers32,0x00010000,"WUDFCoinstaller.dll"

[DestinationDirs]
UMDriverCopy=13

[UMDriverCopy]
DuoController.dll

; =================== Generic ==================================

[Strings]
ManufacturerName="Black-Seraph"
ClassName="DuoController Devices"
DiskName = "DuoController Installation Disk"
WudfRdDisplayName="DuoController User-mode Driver"
ROOT\VID_054C&PID_0DF2.DeviceName="DualSense Edge Wireless Controller"